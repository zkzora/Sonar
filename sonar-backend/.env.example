# Sonar backend — Telegram alert worker config
# Copy to .env and fill in. NEVER commit .env. Address-only — no keys, ever.

# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Hiro API (read-only Stacks node). An API key raises the rate limit.
HIRO_API_URL=https://api.hiro.so
# HIRO_API_KEY=

# How often the monitor loop polls every watched wallet (seconds)
POLL_INTERVAL_SEC=120

# Health-factor level thresholds (env-configurable so a real position can cross them)
#   HF > HF_WATCH              -> SAFE
#   HF_DANGER < HF <= HF_WATCH -> WATCH
#   HF_CRITICAL < HF <= HF_DANGER -> DANGER
#   HF <= HF_CRITICAL          -> CRITICAL
HF_WATCH=1.5
HF_DANGER=1.2
HF_CRITICAL=1.05

# Re-send a CRITICAL alert at most this often (minutes) while it stays critical
CRITICAL_REPEAT_MIN=30

# SQLite database file (on a worker with a persistent volume)
DB_PATH=./sonar.db
