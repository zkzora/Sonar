{
  "name": "sonar-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Sonar — non-custodial, read-only liquidation guardian for sBTC lending on Stacks. Telegram alert worker.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "tsx src/scripts/check.ts"
  },
  "dependencies": {
    "@stacks/network": "^7.0.0",
    "@stacks/transactions": "^7.4.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
